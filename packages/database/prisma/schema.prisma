generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Core: 組織・ユーザー・認証
// ============================================================

model Organization {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  name                 String
  code                 String?   @unique // 事業者コード（MF連携用）
  fiscalMonthEnd       Int       @default(3) @map("fiscal_month_end") // 決算月（1-12）
  industry             String?
  employeeCount        Int?      @map("employee_count")
  planType             PlanType  @default(STARTER) @map("plan_type")
  aiOptOut             Boolean   @default(false) @map("ai_opt_out") // AI機能オプトアウト
  /// 原価計算を運用しているか。false（既定）= 売上原価が信頼できない前提。
  /// 中小企業では原価計算を行っていないケースが多く、その場合 grossProfitMargin（売上総利益率）は
  /// 実態と乖離するため、UI / AI レポートともに参照を控える。
  /// 顧問先ごとに owner / advisor がトグルできる。
  usesCostAccounting   Boolean   @default(false) @map("uses_cost_accounting")
  briefPushEnabled     Boolean   @default(false) @map("brief_push_enabled")
  briefPushHourJst     Int       @default(8) @map("brief_push_hour_jst") // 0-23
  briefSlackWebhookUrl String?   @map("brief_slack_webhook_url")
  /// 公開 HP の URL。AI CFO が事業理解のために参照する。
  websiteUrl           String?   @map("website_url")
  /// 業種だけでは表現できない経営コンテキスト (自由記述)。
  /// AI 質問生成・L3 LLM 検知・将来 Copilot の system prompt に注入する。
  businessContext      String?   @map("business_context")
  contextUpdatedAt     DateTime? @map("context_updated_at")
  contextUpdatedById   String?   @map("context_updated_by_id") @db.Uuid
  contextUpdater       User?     @relation("OrgContextUpdater", fields: [contextUpdatedById], references: [id])
  /// kintone 顧客基本情報から取り込みボタンで prefill した最終時刻。
  /// null = 一度も取り込んでいない (or kintone 連携なし)。
  kintoneSyncedAt      DateTime? @map("kintone_synced_at")
  cashflowCertainty    Json?     @map("cashflow_certainty") // Record<category, "CONFIRMED"|"PLANNED"|"ESTIMATED">
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id])
  departments                 Department[]
  accounts                    AccountMaster[]
  fiscalYears                 FiscalYear[]
  actualEntries               ActualEntry[]
  journalEntries              JournalEntry[]
  kpiDefinitions              KpiDefinition[]
  users                       User[]
  memberships                 OrganizationMembership[]
  notifications               Notification[]
  reports                     Report[]
  auditLogs                   AuditLog[]
  integrations                Integration[]
  cashFlowCategories          CashFlowCategory[]
  cashFlowEntries             CashFlowEntry[]
  cashFlowForecasts           CashFlowForecast[]
  collectionProfiles          CollectionProfile[]
  runwaySnapshots             RunwaySnapshot[]
  loanSimulations             LoanSimulation[]
  calendarEvents              CalendarEvent[]
  actions                     Action[]
  dataSyncLogs                DataSyncLog[]
  businessEvents              BusinessEvent[]
  briefingSnapshots           BriefingSnapshot[]
  agentRuns                   AgentRun[]
  monthlyReviewApprovals      MonthlyReviewApproval[]
  monthlyCloses               MonthlyClose[]
  masterSources               OrganizationMasterSource[]
  riskFindings                RiskFinding[]
  healthSnapshots             HealthSnapshot[]
  choshoVersions              ChoshoVersion[]
  choshoRows                  ChoshoRow[]
  choshoRowComments           ChoshoRowComment[]
  choshoCellComments          ChoshoCellComment[]
  journalReviewFlags          JournalReviewFlag[]
  journalReviewComments       JournalReviewComment[]
  journalReviewSnapshots      JournalReviewSnapshot[]
  journalReviewSnapshotMonths JournalReviewSnapshotMonth[]
  taxSavingDoneItems          TaxSavingDoneItem[]
  bsCleanupTasks              BsCleanupTask[]
  yearEndScheduleItems        YearEndScheduleItemState[]
  locabenState                LocabenState?
  featureStates               FeatureState[]
  loans                       Loan[]
  loanDocuments               LoanDocument[]

  @@unique([id, tenantId])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("organizations")
}

enum PlanType {
  STARTER
  GROWTH
  PRO
}

model Tenant {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  slug          String              @unique
  status        TenantStatus        @default(active)
  plan          PlanType            @default(STARTER)
  isolationMode TenantIsolationMode @default(shared) @map("isolation_mode")
  shardId       String?             @map("shard_id")
  dbSecretName  String?             @map("db_secret_name")
  region        String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  organizations Organization[]
  memberships   TenantMembership[]
  masterSources OrganizationMasterSource[]

  @@map("tenants")
}

enum TenantStatus {
  active
  suspended
  archived
}

enum TenantIsolationMode {
  shared
  dedicated_schema
  dedicated_database
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  password  String // bcrypt hashed
  role      UserRole @default(viewer)
  orgId     String?  @map("org_id") @db.Uuid // null = SEVENRICH顧問スタッフ
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization                  Organization?              @relation(fields: [orgId], references: [id])
  platformMemberships           PlatformMembership[]
  tenantMemberships             TenantMembership[]
  memberships                   OrganizationMembership[]
  budgetVersions                BudgetVersion[]
  aiComments                    AiComment[]                @relation("ReviewedBy")
  notifications                 Notification[]
  auditLogs                     AuditLog[]
  ownedActions                  Action[]                   @relation("ActionOwner")
  createdActions                Action[]                   @relation("ActionCreator")
  actionEvents                  ActionEvent[]
  businessEvents                BusinessEvent[]
  resolvedRiskFindings          RiskFinding[]
  orgContextUpdates             Organization[]             @relation("OrgContextUpdater")
  createdChoshoVersions         ChoshoVersion[]            @relation("ChoshoVersionCreator")
  approvedChoshoVersions        ChoshoVersion[]            @relation("ChoshoVersionApprover")
  confirmedChoshoRows           ChoshoRow[]                @relation("ChoshoRowConfirmer")
  authoredChoshoRowComments     ChoshoRowComment[]         @relation("ChoshoRowCommentAuthor")
  authoredChoshoCellComments    ChoshoCellComment[]        @relation("ChoshoCellCommentAuthor")
  resolvedChoshoCellComments    ChoshoCellComment[]        @relation("ChoshoCellCommentResolver")
  flaggedJournalReviews         JournalReviewFlag[]        @relation("JournalReviewFlagged")
  resolvedJournalReviews        JournalReviewFlag[]        @relation("JournalReviewResolved")
  authoredJournalReviewComments JournalReviewComment[]     @relation("JournalReviewCommentAuthor")
  updatedTaxSavingItems         TaxSavingDoneItem[]        @relation("TaxSavingUpdater")
  updatedBsCleanupTasks         BsCleanupTask[]            @relation("BsCleanupUpdater")
  updatedYearEndScheduleItems   YearEndScheduleItemState[] @relation("YearEndScheduleUpdater")
  updatedLocabenStates          LocabenState[]             @relation("LocabenUpdater")
  updatedFeatureStates          FeatureState[]             @relation("FeatureStateUpdater")

  @@map("users")
}

model PlatformMembership {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  role      PlatformRole
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@index([role])
  @@map("platform_memberships")
}

enum PlatformRole {
  platform_owner
  platform_admin
  platform_support
  security_admin
}

model TenantMembership {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  role      TenantRole
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId, role])
  @@map("tenant_memberships")
}

enum TenantRole {
  firm_owner
  firm_admin
  firm_manager
  firm_advisor
  firm_viewer
}

enum MembershipStatus {
  invited
  active
  suspended
  revoked
}

// factory-hybrid と統一の小文字 5 値。
//
// SevenBoard の G-1 ロール設計：
//   owner   - 事務所オーナー（内部スタッフのみ。orgId=NULL 限定）
//   advisor - 顧問スタッフ（内部スタッフのみ。orgId=NULL 限定）
//   admin   - CL 管理者
//   member  - CL 一般メンバー（編集可・承認不可）
//   viewer  - CL 閲覧専用
//
// 「owner = 会計事務所のみ」という設計を migration
// `20260426010000_user_role_orgid_partition` の CHECK 制約 `user_role_orgid_partition`
// で DB レイヤから強制している:
//   org_id IS NULL     → role ∈ {'owner', 'advisor'}
//   org_id IS NOT NULL → role ∈ {'admin', 'member', 'viewer'}
// これにより顧問先側 owner という概念は DB に作成不可。アプリ側でうっかり
// `role === 'owner'` だけ見るコードを書いても権限漏れに繋がらない。
//
// クロステナント access を判定するヘルパー:
//   isInternalOwner(user)   = user.orgId === null && user.role === 'owner'
//   isInternalAdvisor(user) = user.orgId === null && user.role === 'advisor'
//   isInternalStaff(user)   = いずれか
enum UserRole {
  owner
  admin
  member
  viewer
  advisor
}

/// User と Organization の所属関係（factory-hybrid の OrganizationMembership と同じ概念）。
/// 1 user × 1 org に対して 1 行。
/// - SEVENRICH 事務所スタッフ（owner / advisor）が複数顧問先を担当する場合は user × N orgs の N 行
/// - CL 側ユーザー（viewer 等）は user.orgId と一致する 1 行のみ
/// 既存テーブル名 advisor_assignments は legacy。2026-04-25 に rename して概念統合。
model OrganizationMembership {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  tenantId  String         @map("tenant_id") @db.Uuid
  orgId     String         @map("org_id") @db.Uuid
  /// この user が当該 org に対して持つロール。
  /// SEVENRICH スタッフは 'owner' / 'advisor'、CL 側は 'admin' / 'member' / 'viewer'
  role      UserRole       @default(advisor)
  side      MembershipSide @default(advisor)
  createdAt DateTime       @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([userId, orgId])
  @@index([tenantId, userId])
  @@index([tenantId, orgId])
  @@map("organization_memberships")
}

enum MembershipSide {
  advisor
  client
}

model SystemMasterCatalog {
  id               String             @id @default(uuid()) @db.Uuid
  key              String             @unique
  type             SystemMasterType
  name             String
  status           SystemMasterStatus @default(draft)
  currentVersionId String?            @map("current_version_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  versions SystemMasterVersion[]

  @@index([type, status])
  @@map("system_master_catalogs")
}

model SystemMasterVersion {
  id          String             @id @default(uuid()) @db.Uuid
  catalogId   String             @map("catalog_id") @db.Uuid
  version     Int
  payload     Json
  checksum    String
  status      SystemMasterStatus @default(draft)
  publishedAt DateTime?          @map("published_at")
  createdById String?            @map("created_by_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")

  catalog       SystemMasterCatalog        @relation(fields: [catalogId], references: [id])
  masterSources OrganizationMasterSource[]

  @@unique([catalogId, version])
  @@index([catalogId, status])
  @@map("system_master_versions")
}

enum SystemMasterType {
  account_template
  cash_flow_template
  kpi_template
  report_template
  monthly_review_template
  ai_policy
  permission_catalog
  feature_catalog
}

enum SystemMasterStatus {
  draft
  published
  retired
}

model OrganizationMasterSource {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  orgId                 String   @map("org_id") @db.Uuid
  type                  String
  sourceSystemVersionId String?  @map("source_system_version_id") @db.Uuid
  copiedAt              DateTime @default(now()) @map("copied_at")
  copiedById            String?  @map("copied_by_id") @db.Uuid

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  organization  Organization         @relation(fields: [orgId, tenantId], references: [id, tenantId])
  sourceVersion SystemMasterVersion? @relation(fields: [sourceSystemVersionId], references: [id])

  @@unique([tenantId, orgId, type])
  @@index([tenantId, orgId])
  @@index([sourceSystemVersionId])
  @@map("organization_master_sources")
}

// ============================================================
// 勘定科目・部門
// ============================================================

model Department {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  name         String
  parentId     String?  @map("parent_id") @db.Uuid
  type         String? // "division", "section", "team" 等
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  organization  Organization  @relation(fields: [orgId, tenantId], references: [id, tenantId])
  parent        Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children      Department[]  @relation("DepartmentHierarchy")
  budgetEntries BudgetEntry[]
  actualEntries ActualEntry[]

  @@index([tenantId, orgId])
  @@map("departments")
}

model AccountMaster {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  orgId          String          @map("org_id") @db.Uuid
  code           String // 勘定科目コード
  name           String
  category       AccountCategory
  isVariableCost Boolean         @default(false) @map("is_variable_cost")
  displayOrder   Int             @default(0) @map("display_order")
  externalId     String?         @map("external_id") // MF/freeeの科目ID
  createdAt      DateTime        @default(now()) @map("created_at")

  organization   Organization   @relation(fields: [orgId, tenantId], references: [id, tenantId])
  budgetEntries  BudgetEntry[]
  actualEntries  ActualEntry[]
  debitJournals  JournalEntry[] @relation("DebitAccount")
  creditJournals JournalEntry[] @relation("CreditAccount")

  @@unique([tenantId, orgId, code])
  @@index([tenantId, orgId])
  @@map("account_masters")
}

enum AccountCategory {
  REVENUE // 売上高
  COST_OF_SALES // 売上原価
  SELLING_EXPENSE // 販売費
  ADMIN_EXPENSE // 一般管理費
  NON_OPERATING_INCOME // 営業外収益
  NON_OPERATING_EXPENSE // 営業外費用
  EXTRAORDINARY_INCOME // 特別利益
  EXTRAORDINARY_EXPENSE // 特別損失
  ASSET // 資産
  LIABILITY // 負債
  EQUITY // 純資産
}

// ============================================================
// 予算管理
// ============================================================

model FiscalYear {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  orgId     String           @map("org_id") @db.Uuid
  year      Int // 2025, 2026, ...
  startDate DateTime         @map("start_date") @db.Date
  endDate   DateTime         @map("end_date") @db.Date
  status    FiscalYearStatus @default(OPEN)
  createdAt DateTime         @default(now()) @map("created_at")

  organization   Organization    @relation(fields: [orgId, tenantId], references: [id, tenantId])
  budgetVersions BudgetVersion[]

  @@unique([tenantId, orgId, year])
  @@index([tenantId, orgId])
  @@map("fiscal_years")
}

enum FiscalYearStatus {
  OPEN
  CLOSED
  LOCKED
}

model BudgetVersion {
  id           String       @id @default(uuid()) @db.Uuid
  fiscalYearId String       @map("fiscal_year_id") @db.Uuid
  name         String // "Base", "Upside", "Downside"
  scenarioType ScenarioType @default(BASE)
  createdBy    String       @map("created_by") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  fiscalYear FiscalYear    @relation(fields: [fiscalYearId], references: [id])
  creator    User          @relation(fields: [createdBy], references: [id])
  entries    BudgetEntry[]

  @@map("budget_versions")
}

enum ScenarioType {
  BASE
  UPSIDE
  DOWNSIDE
}

model BudgetEntry {
  id              String   @id @default(uuid()) @db.Uuid
  budgetVersionId String   @map("budget_version_id") @db.Uuid
  accountId       String   @map("account_id") @db.Uuid
  departmentId    String?  @map("department_id") @db.Uuid
  month           DateTime @db.Date // 月初日 (e.g., 2026-04-01)
  amount          Decimal  @db.Decimal(15, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  budgetVersion BudgetVersion @relation(fields: [budgetVersionId], references: [id])
  account       AccountMaster @relation(fields: [accountId], references: [id])
  department    Department?   @relation(fields: [departmentId], references: [id])

  // NOTE: departmentId が NULL の行 (部門なし) は PostgreSQL の NULL DISTINCT 仕様により
  //       下記の複合 @@unique では重複を防げないため、part. unique index
  //       "budget_entry_no_dept_uniq" (budget_version_id, account_id, month) WHERE department_id IS NULL
  //       を生SQL migration (20260602180133_department_id_dedup_root_cause) で別途張って担保している。
  // ⚠️ migrate dev 注意 (WS3 #3): この partial unique index は Prisma スキーマで表現できないため、
  //    `prisma migrate dev` の自動生成 SQL は差分を検知して `DROP INDEX "budget_entry_no_dept_uniq";`
  //    を吐く。生成された migration.sql は必ず目視し、当該 DROP INDEX 行を除去してからコミットすること。
  @@unique([budgetVersionId, accountId, departmentId, month], name: "budget_entry_with_dept")
  @@index([budgetVersionId, month])
  @@map("budget_entries")
}

// ============================================================
// 実績データ
// ============================================================

model ActualEntry {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  orgId        String     @map("org_id") @db.Uuid
  accountId    String     @map("account_id") @db.Uuid
  departmentId String?    @map("department_id") @db.Uuid
  month        DateTime   @db.Date
  amount       Decimal    @db.Decimal(15, 2)
  source       DataSource @default(MANUAL)
  syncedAt     DateTime?  @map("synced_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId, tenantId], references: [id, tenantId])
  account      AccountMaster @relation(fields: [accountId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])

  // NOTE: departmentId が NULL の行 (部門なし) は PostgreSQL の NULL DISTINCT 仕様により
  //       下記の複合 @@unique では重複を防げないため、part. unique index
  //       "actual_entry_no_dept_uniq" (tenant_id, org_id, account_id, month) WHERE department_id IS NULL
  //       を生SQL migration (20260602180133_department_id_dedup_root_cause) で別途張って担保している。
  // ⚠️ migrate dev 注意 (WS3 #3): この partial unique index は Prisma スキーマで表現できないため、
  //    `prisma migrate dev` の自動生成 SQL は差分を検知して `DROP INDEX "actual_entry_no_dept_uniq";`
  //    を吐く。生成された migration.sql は必ず目視し、当該 DROP INDEX 行を除去してからコミットすること。
  @@unique([tenantId, orgId, accountId, departmentId, month], name: "actual_entry_with_dept")
  @@index([tenantId, orgId, month])
  @@index([orgId, month])
  @@map("actual_entries")
}

enum DataSource {
  MANUAL
  MF_CLOUD
  FREEE
  CSV_IMPORT
  BOOKKEEPING_PLUGIN
}

model JournalEntry {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  orgId           String     @map("org_id") @db.Uuid
  journalDate     DateTime   @map("journal_date") @db.Date
  debitAccountId  String     @map("debit_account_id") @db.Uuid
  creditAccountId String     @map("credit_account_id") @db.Uuid
  amount          Decimal    @db.Decimal(15, 2)
  description     String?
  externalId      String?    @map("external_id") // MF/freeeの仕訳ID
  source          DataSource @default(MANUAL)
  createdAt       DateTime   @default(now()) @map("created_at")

  organization  Organization  @relation(fields: [orgId, tenantId], references: [id, tenantId])
  debitAccount  AccountMaster @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount AccountMaster @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([tenantId, orgId, journalDate])
  @@index([orgId, journalDate])
  @@map("journal_entries")
}

// ============================================================
// KPI管理
// ============================================================

model KpiDefinition {
  id       String      @id @default(uuid()) @db.Uuid
  tenantId String      @map("tenant_id") @db.Uuid
  orgId    String      @map("org_id") @db.Uuid
  name     String // "MRR", "ARR", "Churn Rate" 等
  formula  String? // 計算式（参照用）
  unit     String      @default("JPY") // "JPY", "%", "件", "人" 等
  category KpiCategory @default(CUSTOM)

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  values       KpiValue[]

  @@unique([tenantId, orgId, name])
  @@index([tenantId, orgId])
  @@map("kpi_definitions")
}

enum KpiCategory {
  SAAS // MRR, ARR, Churn, LTV, CAC
  SALES // 受注件数, 成約率, 客単価
  HR // 従業員数, 離職率
  FINANCIAL // 粗利率, 営業利益率
  CUSTOM
}

model KpiValue {
  id       String     @id @default(uuid()) @db.Uuid
  kpiId    String     @map("kpi_id") @db.Uuid
  tenantId String     @map("tenant_id") @db.Uuid
  orgId    String     @map("org_id") @db.Uuid // RLS用に直接保持
  month    DateTime   @db.Date
  value    Decimal    @db.Decimal(15, 4)
  source   DataSource @default(MANUAL)

  kpiDefinition KpiDefinition @relation(fields: [kpiId], references: [id])

  @@unique([kpiId, month])
  @@index([tenantId, orgId, month])
  @@index([orgId, month])
  @@map("kpi_values")
}

// ============================================================
// レポート・AIコメント
// ============================================================

model Report {
  id        String     @id @default(uuid()) @db.Uuid
  tenantId  String     @map("tenant_id") @db.Uuid
  orgId     String     @map("org_id") @db.Uuid
  name      String
  type      ReportType
  config    Json       @default("{}") // レポート設定JSON
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  aiComments   AiComment[]

  @@index([tenantId, orgId])
  @@map("reports")
}

enum ReportType {
  VARIANCE // 予実差異
  PL // 損益計算書
  BS // 貸借対照表
  CF // キャッシュフロー計算書
  VARIABLE_COST // 変動損益計算書
  CUSTOM // カスタムレポート
  CASHFLOW // 資金繰り表
}

model AiComment {
  id              String          @id @default(uuid()) @db.Uuid
  reportId        String          @map("report_id") @db.Uuid
  cellRef         String?         @map("cell_ref") // "revenue.2026-03" 等
  content         String
  confidenceScore Float?          @map("confidence_score")
  reviewedBy      String?         @map("reviewed_by") @db.Uuid
  status          AiCommentStatus @default(PENDING)
  rejectReason    String?         @map("reject_reason")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  report   Report @relation(fields: [reportId], references: [id])
  reviewer User?  @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@map("ai_comments")
}

enum AiCommentStatus {
  PENDING
  APPROVED
  MODIFIED
  REJECTED
}

// ============================================================
// 資金繰り
// ============================================================

model CashFlowCategory {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  name           String // "売上入金", "人件費", "家賃" 等
  direction      CashDirection // IN or OUT
  cfType         CashFlowType // OPERATING, INVESTING, FINANCING
  isFixed        Boolean       @default(false) @map("is_fixed")
  recurrenceRule String?       @map("recurrence_rule") // "MONTHLY_10", "MONTHLY_END" 等
  displayOrder   Int           @default(0) @map("display_order")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization    @relation(fields: [orgId, tenantId], references: [id, tenantId])
  entries      CashFlowEntry[]

  @@index([tenantId, orgId])
  @@map("cash_flow_categories")
}

enum CashDirection {
  IN
  OUT
}

enum CashFlowType {
  OPERATING // 営業活動
  INVESTING // 投資活動
  FINANCING // 財務活動
}

model CashFlowEntry {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  entryDate    DateTime @map("entry_date") @db.Date
  amount       Decimal  @db.Decimal(15, 2)
  isActual     Boolean  @default(false) @map("is_actual")
  tradePartner String?  @map("trade_partner") // 取引先名
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization     @relation(fields: [orgId, tenantId], references: [id, tenantId])
  category     CashFlowCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId, orgId, entryDate])
  @@index([orgId, entryDate])
  @@map("cash_flow_entries")
}

model CashFlowForecast {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  orgId          String              @map("org_id") @db.Uuid
  forecastDate   DateTime            @map("forecast_date") @db.Date
  granularity    ForecastGranularity
  openingBalance Decimal             @map("opening_balance") @db.Decimal(15, 2)
  inflow         Decimal             @db.Decimal(15, 2)
  outflow        Decimal             @db.Decimal(15, 2)
  closingBalance Decimal             @map("closing_balance") @db.Decimal(15, 2)
  scenarioType   ScenarioType        @default(BASE) @map("scenario_type")
  createdAt      DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, forecastDate, granularity, scenarioType])
  @@index([tenantId, orgId])
  @@map("cash_flow_forecasts")
}

enum ForecastGranularity {
  DAILY
  WEEKLY
  MONTHLY
}

model CollectionProfile {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  tradePartner     String   @map("trade_partner") // 取引先名
  avgDaysToCollect Int      @default(60) @map("avg_days_to_collect") // デフォルト60日（末締め翌月末）
  paymentPattern   String?  @map("payment_pattern") // "MONTHLY_END", "NET30" 等
  riskScore        Float    @default(0) @map("risk_score") // 0.0-1.0
  lastUpdated      DateTime @default(now()) @map("last_updated")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, tradePartner])
  @@index([tenantId, orgId])
  @@map("collection_profiles")
}

model RunwaySnapshot {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  orgId           String     @map("org_id") @db.Uuid
  snapshotDate    DateTime   @map("snapshot_date") @db.Date
  cashBalance     Decimal    @map("cash_balance") @db.Decimal(15, 2)
  monthlyBurnRate Decimal    @map("monthly_burn_rate") @db.Decimal(15, 2)
  runwayMonths    Float      @map("runway_months")
  alertLevel      AlertLevel @default(SAFE) @map("alert_level")
  createdAt       DateTime   @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@index([tenantId, orgId, snapshotDate])
  @@map("runway_snapshots")
}

enum AlertLevel {
  SAFE // 12ヶ月以上
  CAUTION // 6-12ヶ月
  WARNING // 3-6ヶ月
  CRITICAL // 3ヶ月未満
}

model LoanSimulation {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  orgId            String        @map("org_id") @db.Uuid
  name             String // "日本政策金融公庫 2026年" 等
  principal        Decimal       @db.Decimal(15, 2)
  interestRate     Float         @map("interest_rate") // 年利（%）
  termMonths       Int           @map("term_months")
  graceMonths      Int           @default(0) @map("grace_months")
  repaymentType    RepaymentType @default(EQUAL_INSTALLMENT) @map("repayment_type")
  monthlyRepayment Decimal?      @map("monthly_repayment") @db.Decimal(15, 2)
  startDate        DateTime?     @map("start_date") @db.Date
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@index([tenantId, orgId])
  @@map("loan_simulations")
}

enum RepaymentType {
  EQUAL_INSTALLMENT // 元利均等
  EQUAL_PRINCIPAL // 元金均等
  BULLET // 一括返済
}

// ============================================================
// 外部連携
// ============================================================

model Integration {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  orgId        String              @map("org_id") @db.Uuid
  provider     IntegrationProvider
  accessToken  String?             @map("access_token")
  refreshToken String?             @map("refresh_token")
  tokenExpiry  DateTime?           @map("token_expiry")
  config       Json                @default("{}") // 科目マッピング等
  lastSyncAt   DateTime?           @map("last_sync_at")
  syncStatus   SyncStatus          @default(NEVER) @map("sync_status")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, provider])
  @@index([tenantId, orgId])
  @@map("integrations")
}

enum IntegrationProvider {
  MF_CLOUD
  FREEE
  BOOKKEEPING_PLUGIN
}

enum SyncStatus {
  NEVER
  SUCCESS
  FAILED
  IN_PROGRESS
}

// ============================================================
// 通知・監査
// ============================================================

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  orgId     String           @map("org_id") @db.Uuid
  userId    String?          @map("user_id") @db.Uuid // null = 全員向け
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json             @default("{}") // リンク先等
  createdAt DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([tenantId, orgId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  ANOMALY_ALERT // 異常値アラート
  CASHFLOW_ALERT // 資金ショートアラート
  SYNC_ERROR // 同期エラー
  AI_COMMENT // AIコメント生成完了
  ADVISOR_COMMENT // 顧問コメント
  SYSTEM // システム通知
}

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  action          String // "CREATE", "UPDATE", "DELETE", "IMPERSONATE"
  resource        String // "budget_entry", "actual_entry" 等
  resourceId      String?  @map("resource_id")
  beforeValue     Json?    @map("before_value")
  afterValue      Json?    @map("after_value")
  ipAddress       String?  @map("ip_address")
  isImpersonation Boolean  @default(false) @map("is_impersonation") // 顧問スタッフのなりすましアクセス
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  user         User         @relation(fields: [userId], references: [id])

  @@index([tenantId, orgId, createdAt])
  @@index([orgId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// カレンダーイベント
// ============================================================

model CalendarEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  title       String
  date        DateTime @db.Date
  type        String   @default("task") // "deadline", "meeting", "task"
  status      String   @default("upcoming") // "upcoming", "completed", "cancelled"
  description String?
  assigneeId  String?  @map("assignee_id") @db.Uuid
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@index([tenantId, orgId, date])
  @@index([orgId, date])
  @@map("calendar_events")
}

// ============================================================
// Action共通オブジェクト（§5 tier-s-spec）
// ============================================================

model Action {
  id                   String             @id @default(uuid()) @db.Uuid
  tenantId             String             @map("tenant_id") @db.Uuid
  orgId                String             @map("org_id") @db.Uuid
  title                String
  description          String?
  sourceScreen         ActionSourceScreen @map("source_screen")
  sourceRef            Json               @default("{}") @map("source_ref")
  severity             ActionSeverity     @default(MEDIUM)
  ownerRole            ActionOwnerRole    @default(ADVISOR) @map("owner_role")
  ownerUserId          String?            @map("owner_user_id") @db.Uuid
  dueDate              DateTime?          @map("due_date") @db.Date
  status               ActionStatus       @default(NOT_STARTED)
  linkedSlackThreadUrl String?            @map("linked_slack_thread_url")
  createdBy            String             @map("created_by") @db.Uuid
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  completedAt          DateTime?          @map("completed_at")

  organization Organization  @relation(fields: [orgId, tenantId], references: [id, tenantId])
  owner        User?         @relation("ActionOwner", fields: [ownerUserId], references: [id])
  creator      User          @relation("ActionCreator", fields: [createdBy], references: [id])
  events       ActionEvent[]

  @@index([tenantId, orgId, status])
  @@index([tenantId, orgId, dueDate])
  @@index([tenantId, orgId, sourceScreen])
  @@index([orgId, status])
  @@index([orgId, dueDate])
  @@index([orgId, sourceScreen])
  @@map("actions")
}

enum ActionStatus {
  NOT_STARTED // 未着手
  IN_PROGRESS // 進行中
  COMPLETED // 完了
  ON_HOLD // 保留
}

enum ActionSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ActionOwnerRole {
  ADVISOR // 顧問
  EXECUTIVE // 経営者
  ACCOUNTING // 経理担当
}

enum ActionSourceScreen {
  DASHBOARD
  CASHFLOW
  MONTHLY_REVIEW
  AI_REPORT
  ALERTS
  VARIANCE
  KPI
  MANUAL
}

model ActionEvent {
  id        String          @id @default(uuid()) @db.Uuid
  actionId  String          @map("action_id") @db.Uuid
  eventType ActionEventType @map("event_type")
  eventBy   String          @map("event_by") @db.Uuid
  eventAt   DateTime        @default(now()) @map("event_at")
  payload   Json            @default("{}")

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [eventBy], references: [id])

  @@index([actionId, eventAt])
  @@map("action_events")
}

enum ActionEventType {
  CREATED
  REASSIGNED
  STATUS_CHANGED
  NOTE_ADDED
  SLACK_LINKED
}

// ============================================================
// データ鮮度ログ（§6.1 tier-s-spec）
// ============================================================

model DataSyncLog {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  orgId        String     @map("org_id") @db.Uuid
  source       SyncSource
  status       SyncResult
  errorMessage String?    @map("error_message")
  syncedAt     DateTime   @default(now()) @map("synced_at")
  durationMs   Int?       @map("duration_ms")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@index([tenantId, orgId, source, syncedAt])
  @@index([orgId, source, syncedAt])
  @@map("data_sync_logs")
}

enum SyncSource {
  MF_CLOUD
  KINTONE
  SLACK
  TAX_PLUGIN
  BOOKKEEPING_PLUGIN
  MANUAL
}

enum SyncResult {
  SUCCESS
  PARTIAL
  FAILED
}

// ============================================================
// 経営イベントログ（§6.2 tier-s-spec）
// ============================================================

model BusinessEvent {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  eventDate  DateTime @map("event_date") @db.Date
  eventType  String   @map("event_type") // 値上げ実施/大型採用/賞与支給/広告投下/借入実行/設備投資 等
  title      String
  note       String?
  impactTags String[] @default([]) @map("impact_tags") // sales / cost / cash / headcount
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  creator      User         @relation(fields: [createdBy], references: [id])

  @@index([tenantId, orgId, eventDate])
  @@index([orgId, eventDate])
  @@map("business_events")
}

/// エージェント実行履歴（brief/sentinel/drafter/auditor/copilot）
/// 「いつ・何を根拠に・どう出力したか」を後から再現するための監査ログ
/// input/output/toolCalls は任意の JSON を格納
model AgentRun {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  orgId        String         @map("org_id") @db.Uuid
  agentKey     AgentRunKey    @map("agent_key")
  mode         AgentRunMode?
  generatedAt  DateTime       @default(now()) @map("generated_at")
  fiscalYear   Int?           @map("fiscal_year")
  endMonth     Int?           @map("end_month")
  userId       String?        @map("user_id") @db.Uuid
  input        Json           @default("{}")
  output       Json           @default("{}")
  toolCalls    Json           @default("[]") @map("tool_calls")
  status       AgentRunStatus @default(SUCCESS)
  errorMessage String?        @map("error_message")
  durationMs   Int?           @map("duration_ms")
  createdAt    DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@index([tenantId, orgId, agentKey, generatedAt])
  @@index([orgId, agentKey, generatedAt])
  @@index([orgId, generatedAt])
  @@map("agent_runs")
}

enum AgentRunKey {
  BRIEF
  SENTINEL
  DRAFTER
  AUDITOR
  COPILOT
}

enum AgentRunMode {
  OBSERVE
  DIALOG
  EXECUTE
  CRON
}

enum AgentRunStatus {
  SUCCESS
  FALLBACK
  FAILED
}

/// 朝のサマリー（briefエージェント）のスナップショット履歴
/// headlines は {title, body, source, severity, linkHref?} の配列。JSONで保持。
model BriefingSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  generatedAt    DateTime @default(now()) @map("generated_at")
  greeting       String
  headlines      Json     @default("[]")
  fallbackReason String?  @map("fallback_reason")
  urgentCount    Int      @default(0) @map("urgent_count")
  thisWeekCount  Int      @default(0) @map("this_week_count")
  headlineCount  Int      @default(0) @map("headline_count")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@index([tenantId, orgId, generatedAt])
  @@index([orgId, generatedAt])
  @@map("briefing_snapshots")
}

/// 月次レビューの最終承認状態。org × fiscalYear × month で1件。
/// 顧問が「レビュー済み・顧客に納品OK」を明示する承認ステップ。
model MonthlyReviewApproval {
  id         String                      @id @default(uuid()) @db.Uuid
  tenantId   String                      @map("tenant_id") @db.Uuid
  orgId      String                      @map("org_id") @db.Uuid
  fiscalYear Int                         @map("fiscal_year")
  month      Int // 1-12 会計年度内の対象月
  status     MonthlyReviewApprovalStatus @default(DRAFT)
  approvedBy String?                     @map("approved_by") @db.Uuid
  approvedAt DateTime?                   @map("approved_at")
  comment    String?
  createdAt  DateTime                    @default(now()) @map("created_at")
  updatedAt  DateTime                    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, fiscalYear, month])
  @@index([tenantId, orgId, fiscalYear])
  @@index([orgId, fiscalYear])
  @@map("monthly_review_approvals")
}

enum MonthlyReviewApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// 月次締め (Monthly Close)
// kintone未連携でも「現在対象月」を確定させ、レビュー進捗を追跡する。
// status=IN_REVIEW の最新月が SevenBoard デフォルト表示月になる。
// ============================================================

model MonthlyClose {
  id         String             @id @default(uuid()) @db.Uuid
  tenantId   String             @map("tenant_id") @db.Uuid
  orgId      String             @map("org_id") @db.Uuid
  fiscalYear Int                @map("fiscal_year")
  month      Int // 1-12 (カレンダー月)
  status     MonthlyCloseStatus @default(OPEN)
  changedAt  DateTime           @default(now()) @map("changed_at")
  changedBy  String?            @map("changed_by") @db.Uuid
  /// CLOSED時点のKPIスナップショット（後の数字変更で締め値を保護）
  snapshot   Json?
  note       String?

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, fiscalYear, month])
  @@index([tenantId, orgId, fiscalYear])
  @@index([tenantId, orgId, status])
  @@index([orgId, fiscalYear])
  @@index([orgId, status])
  @@map("monthly_closes")
}

enum MonthlyCloseStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

/// AI CFO の異常検知 (会計レビュー ② 要確認アイテム) で永続化される検知結果。
/// 3 層構造: L1_RULE (決定的ルール、例: マイナス残高), L2_STATS (会社固有の正常レンジからの逸脱),
/// L3_LLM (摘要文の意味的異常)。L1+L2 は MF 同期完了時に自動実行、L3 は手動ボタンのみ。
model RiskFinding {
  id                String        @id @default(uuid()) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  orgId             String        @map("org_id") @db.Uuid
  fiscalYear        Int           @map("fiscal_year")
  month             Int // 1-12 (カレンダー月)
  layer             RiskLayer // L1_RULE / L2_STATS / L3_LLM
  ruleKey           String        @map("rule_key") // 'NEGATIVE_BALANCE' / 'AR_LONG_OVERDUE' 等。layer + ruleKey + scopeKey で識別
  /// 科目コード・取引先 ID など、同一ルール内の対象識別子。
  /// Prisma の compound unique は NULL を distinct 扱いして upsert が壊れるため、
  /// 対象なしの場合は空文字をデフォルト値として使う。
  scopeKey          String        @default("") @map("scope_key")
  title             String // "接待交際費が通常の3倍 (¥45万)"
  body              String // 顧問・社長向けの本文
  riskScore         Int           @map("risk_score") // 0-100
  flags             Json          @default("[]") // ["amount_x3", "first_occurrence"] 等
  evidence          Json          @default("{}") // { accountCode, journalIds, period, baseline, current }
  recommendedAction String        @map("recommended_action") // 推奨アクション (CFO 原則: 提示しっぱなし禁止)
  status            FindingStatus @default(OPEN)
  resolvedById      String?       @map("resolved_by_id") @db.Uuid
  resolvedAt        DateTime?     @map("resolved_at")
  detectedAt        DateTime      @default(now()) @map("detected_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  resolver     User?        @relation(fields: [resolvedById], references: [id])

  /// 同一の検知 (org × period × layer × ruleKey × scopeKey) は 1 行に upsert する
  @@unique([tenantId, orgId, fiscalYear, month, layer, ruleKey, scopeKey])
  @@index([tenantId, orgId, fiscalYear, month, status])
  @@index([orgId, status, riskScore(sort: Desc)])
  @@index([orgId, layer])
  @@map("risk_findings")
}

enum RiskLayer {
  L1_RULE // 決定的ルール (TS 関数で計算)
  L2_STATS // 統計的逸脱 (過去 24 ヶ月の正常レンジから外れる)
  L3_LLM // LLM による摘要・パターンの意味的異常
}

enum FindingStatus {
  OPEN // 未対応 (デフォルト)
  CONFIRMED // 確認済 (内容を見た、放置でよい or 後で対応)
  DISMISSED // 対応不要 (誤検知 or 該当しない)
  RESOLVED // 対応完了 (修正仕訳・対策実施済)
}

/// AI CFO 経営健康モニター (会計レビュー ① 健康サマリー) のスナップショット。
/// MF 同期完了時に自動計算され、各 org の健康状態を時系列で追える。
/// 100 点満点 = 活動性 40 + 安全性 40 + 効率性 20 の構成。
model HealthSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  /// スナップショット対象月の月初日 (例: 2026-04-01)
  snapshotDate DateTime @map("snapshot_date") @db.Date
  /// 0-100 の総合スコア
  score        Int
  /// 1 ヶ月前のスナップショットの score。前月比の表示に使用
  prevScore    Int?     @map("prev_score")
  /// {"activity": 30, "safety": 35, "efficiency": 8} のような点数内訳
  breakdown    Json     @default("{}")
  /// 計算時点の主要財務指標スナップショット (FinancialIndicators 互換)
  indicators   Json     @default("{}")
  /// AI が生成した「今月の経営者に聞くべき 5 問」(string[])
  aiQuestions  Json     @default("[]") @map("ai_questions")
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, snapshotDate])
  @@index([tenantId, orgId, snapshotDate(sort: Desc)])
  @@map("health_snapshots")
}

/// 残高調書 (Chosho) — 月次/決算レビュー用の月末残高一覧スナップショット。
/// MF 推移表 API から月別残高を引き、3階層 (勘定→補助→取引先) で並べる。
/// 異常検知ルール (零残高違反 / 3ヶ月以上滞留) で赤セル表示し、行・セル単位でコメント可能。
model ChoshoVersion {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  fiscalYear    Int          @map("fiscal_year")
  /// この調書がカバーする「最新月」(1-12 のカレンダー月)。月次=その月、決算=期末月。
  selectedMonth Int          @map("selected_month")
  status        ChoshoStatus @default(DRAFT)
  title         String?
  createdById   String?      @map("created_by_id") @db.Uuid
  approvedById  String?      @map("approved_by_id") @db.Uuid
  approvedAt    DateTime?    @map("approved_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  creator      User?        @relation("ChoshoVersionCreator", fields: [createdById], references: [id])
  approver     User?        @relation("ChoshoVersionApprover", fields: [approvedById], references: [id])
  rows         ChoshoRow[]

  /// 子テーブル (ChoshoRow) からの複合 FK ターゲット。tenantId/orgId 整合をDBで保証する。
  // ⚠️ migrate dev 注意 (WS3 #3): このモデルには Prisma で表現できない partial unique index
  //    "chosho_versions_one_approved_per_period" (tenant_id, org_id, fiscal_year, selected_month)
  //    WHERE status = 'APPROVED' が生SQL migration (20260509120000_add_chosho_review) で張られている。
  //    `prisma migrate dev` は差分を検知して `DROP INDEX "chosho_versions_one_approved_per_period";`
  //    を吐くので、生成された migration.sql を必ず目視し当該 DROP INDEX 行を除去してからコミットすること。
  @@unique([id, tenantId, orgId])
  @@index([tenantId, orgId, fiscalYear])
  @@index([tenantId, orgId, status])
  @@map("chosho_versions")
}

enum ChoshoStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

/// 調書の 1 行。3階層を level で表現:
/// 0=大区分(資産の部 等) / 1=勘定(普通預金 等) / 2=補助(銀行口座 等) / 3=取引先
model ChoshoRow {
  id                String             @id @default(uuid()) @db.Uuid
  versionId         String             @map("version_id") @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  orgId             String             @map("org_id") @db.Uuid
  level             Int
  displayOrder      Int                @default(0) @map("display_order")
  parentRowId       String?            @map("parent_row_id") @db.Uuid
  accountCode       String?            @map("account_code")
  accountName       String             @map("account_name")
  subaccountName    String?            @map("subaccount_name")
  partnerName       String?            @map("partner_name")
  /// 月別残高: {"4": 12345.0, "5": 23456.0, ...}
  monthlyBalances   Json               @default("{}") @map("monthly_balances")
  expectedRule      ChoshoExpectedRule @default(NONE) @map("expected_rule")
  /// 期待残高 (EXPECTED_VALUE ルールのときだけ意味を持つ)。
  /// NULL = 未設定。0 / 300万 / 55,000 等、会計士が任意で指定する。
  expectedValue     Decimal?           @map("expected_value") @db.Decimal
  agingCheckEnabled Boolean            @default(false) @map("aging_check_enabled")
  evidenceText      String?            @map("evidence_text")
  notes             String?
  confirmed         Boolean            @default(false)
  confirmedById     String?            @map("confirmed_by_id") @db.Uuid
  confirmedAt       DateTime?          @map("confirmed_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  /// 同一 (versionId, tenantId, orgId) でないと FK が成立しない複合参照。
  /// これにより別テナント/別組織/別版の version を子から指すことが DB レベルで不可能。
  version      ChoshoVersion       @relation(fields: [versionId, tenantId, orgId], references: [id, tenantId, orgId], onDelete: Cascade)
  organization Organization        @relation(fields: [orgId, tenantId], references: [id, tenantId])
  /// 親行も同じ (versionId, tenantId, orgId) 内に制限。階層は同一スナップショット内でのみ成立。
  parent       ChoshoRow?          @relation("ChoshoRowParent", fields: [parentRowId, versionId, tenantId, orgId], references: [id, versionId, tenantId, orgId])
  children     ChoshoRow[]         @relation("ChoshoRowParent")
  confirmer    User?               @relation("ChoshoRowConfirmer", fields: [confirmedById], references: [id])
  rowComments  ChoshoRowComment[]
  cellComments ChoshoCellComment[]

  /// 自己参照 (parent) からの 4 列複合 FK ターゲット。同一版内に制限。
  @@unique([id, versionId, tenantId, orgId])
  /// 子テーブル (ChoshoRowComment / ChoshoCellComment) からの 3 列複合 FK ターゲット。
  @@unique([id, tenantId, orgId])
  @@index([versionId, displayOrder])
  @@index([tenantId, orgId])
  @@index([parentRowId])
  @@map("chosho_rows")
}

enum ChoshoExpectedRule {
  NONE
  /// 期待残高チェック。chosho_rows.expected_value と selectedMonth 残高の一致を見る。
  /// 旧 ZERO は expected_value=0 として吸収。300 万 / 55,000 円等、任意の値を扱える。
  EXPECTED_VALUE
  AGING_3M
}

/// 行右端コメントボタンから残すコメント。1行に複数 (1:N)。URL を JSON 配列で持てる。
model ChoshoRowComment {
  id        String   @id @default(uuid()) @db.Uuid
  rowId     String   @map("row_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  body      String
  /// 添付 URL の配列 (string[])
  urls      Json     @default("[]")
  authorId  String?  @map("author_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// 同一 (rowId, tenantId, orgId) でないと FK が成立しない複合参照。別テナント/別組織の row を指せない。
  row          ChoshoRow    @relation(fields: [rowId, tenantId, orgId], references: [id, tenantId, orgId], onDelete: Cascade)
  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  author       User?        @relation("ChoshoRowCommentAuthor", fields: [authorId], references: [id])

  @@index([rowId, createdAt])
  @@index([tenantId, orgId])
  @@map("chosho_row_comments")
}

/// セルコメントスレッド。 1 (org, fiscalYear, month, rowKey) に複数 root + 返信 (parent_comment_id)。
/// resolved_at は root コメント単位で「解決済」状態を持つ。
///
/// 旧設計 (saved version の row_id 紐付け) からの移行中。
///   - 新 API: (fiscalYear, month, rowKey) で書き読みする — preview/saved 両方から見える
///   - 旧 API: rowId を持つレコードはまだ動く (saved version 経由の delete 等)
///   - rowId は nullable に変更済 (新 API で書く時は NULL)
model ChoshoCellComment {
  id              String             @id @default(uuid()) @db.Uuid
  /// 旧設計の chosho_rows.id 参照。 新 API で書く時は NULL。 既存データは best-effort で残置。
  rowId           String?            @map("row_id") @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  orgId           String             @map("org_id") @db.Uuid
  /// 1-12 のカレンダー月。どのセルへのコメントか。
  month           Int
  /// 新設計: 会計年度 (fiscalYear)。 旧データは migration で best-effort 埋め。
  fiscalYear      Int?               @map("fiscal_year")
  /// 新設計: 行識別子 (preview builder の rowKey をそのまま使用)。
  /// version 横断で同じ場所のセルを指す stable な key。
  rowKey          String?            @map("row_key")
  /// NULL = root コメント、UUID = 返信
  parentCommentId String?            @map("parent_comment_id") @db.Uuid
  body            String
  urls            Json               @default("[]")
  /// 異常種別。 null = ユーザーが任意セルに付けたメモ (異常検知なし)。
  anomalyType     ChoshoAnomalyType? @map("anomaly_type")
  authorId        String?            @map("author_id") @db.Uuid
  resolvedAt      DateTime?          @map("resolved_at")
  resolvedById    String?            @map("resolved_by_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  /// 旧 FK: 同一 (rowId, tenantId, orgId) でないと成立しない複合参照。 rowId NULL ならスキップ。
  row          ChoshoRow?          @relation(fields: [rowId, tenantId, orgId], references: [id, tenantId, orgId], onDelete: Cascade)
  organization Organization        @relation(fields: [orgId, tenantId], references: [id, tenantId])
  author       User?               @relation("ChoshoCellCommentAuthor", fields: [authorId], references: [id])
  resolvedBy   User?               @relation("ChoshoCellCommentResolver", fields: [resolvedById], references: [id])
  parent       ChoshoCellComment?  @relation("ChoshoCellCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies      ChoshoCellComment[] @relation("ChoshoCellCommentReplies")

  @@index([rowId, month])
  @@index([parentCommentId])
  @@index([tenantId, orgId])
  /// 新 API の主検索パス: (org, fy, month, rowKey)
  @@index([tenantId, orgId, fiscalYear, month, rowKey], map: "chosho_cell_comments_org_fy_month_rowkey_idx")
  @@map("chosho_cell_comments")
}

enum ChoshoAnomalyType {
  /// 期待残高違反 (expected_value と一致しない)。旧 ZERO_VIOLATION の汎化版。
  EXPECTED_VALUE_VIOLATION
  AGING_3M
}

/// 仕訳レビュー: 「要確認」フラグ (Phase 2 / Unit 2-1)。
/// 1 仕訳 (org × journal_id) に 1 行。resolved_at IS NULL なら未解決 (UI で赤ハイライト)。
model JournalReviewFlag {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  fiscalYear   Int       @map("fiscal_year")
  month        Int
  /// MF 仕訳の id (UUID 形式の場合もあるが TEXT で受ける)
  journalId    String    @map("journal_id")
  flaggedAt    DateTime  @default(now()) @map("flagged_at")
  flaggedById  String?   @map("flagged_by_id") @db.Uuid
  resolvedAt   DateTime? @map("resolved_at")
  resolvedById String?   @map("resolved_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  flaggedBy    User?        @relation("JournalReviewFlagged", fields: [flaggedById], references: [id])
  resolvedBy   User?        @relation("JournalReviewResolved", fields: [resolvedById], references: [id])

  // ⚠️ migrate dev 注意 (WS3 #3): このモデルには Prisma で表現できない partial index
  //    "journal_review_flags_unresolved_idx" (... ) WHERE resolved_at IS NULL が生SQL migration
  //    (20260510120000_add_journal_review_flags) で張られている (未解決フラグの絞り込み用)。
  //    `prisma migrate dev` は差分を検知して `DROP INDEX "journal_review_flags_unresolved_idx";`
  //    を吐くので、生成された migration.sql を必ず目視し当該 DROP INDEX 行を除去してからコミットすること。
  @@unique([tenantId, orgId, journalId])
  @@index([tenantId, orgId, fiscalYear, month])
  @@map("journal_review_flags")
}

/// 仕訳レビュー: 1 仕訳に対するコメントスレッド (Phase 2 / Unit 2-2)。
/// parent_comment_id NULL = root コメント、UUID = 返信。
model JournalReviewComment {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  /// MF 仕訳の id (UUID 形式)。FK なし (MF が正本)
  journalId       String   @map("journal_id")
  parentCommentId String?  @map("parent_comment_id") @db.Uuid
  body            String
  /// 添付 URL の配列 (string[])
  urls            Json     @default("[]")
  authorId        String?  @map("author_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization           @relation(fields: [orgId, tenantId], references: [id, tenantId])
  parent       JournalReviewComment?  @relation("JournalReviewCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies      JournalReviewComment[] @relation("JournalReviewCommentReplies")
  author       User?                  @relation("JournalReviewCommentAuthor", fields: [authorId], references: [id])

  @@index([tenantId, orgId, journalId, createdAt])
  @@index([parentCommentId])
  @@map("journal_review_comments")
}

/// 仕訳レビュー: MF 仕訳の表示用 snapshot。
/// memo タブの会計期間表示で MF API を毎回全月取得しないため、月単位で累積キャッシュする。
model JournalReviewSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  fiscalYear    Int      @map("fiscal_year")
  month         Int
  journalId     String   @map("journal_id")
  number        String?
  issueDate     String?  @map("issue_date")
  description   String?
  partnerName   String?  @map("partner_name")
  debitSummary  Json     @default("[]") @map("debit_summary")
  creditSummary Json     @default("[]") @map("credit_summary")
  totalAmount   Decimal  @default(0) @map("total_amount") @db.Decimal(18, 2)
  fetchedAt     DateTime @default(now()) @map("fetched_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, journalId])
  @@index([tenantId, orgId, fiscalYear, month])
  @@map("journal_review_snapshots")
}

/// 仕訳レビュー: 月単位 snapshot の取得済みマーカー。
/// 仕訳が0件の月でも再取得を避けるため、snapshot 本体とは別に管理する。
model JournalReviewSnapshotMonth {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  fiscalYear Int      @map("fiscal_year")
  month      Int
  fetchedAt  DateTime @default(now()) @map("fetched_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])

  @@unique([tenantId, orgId, fiscalYear, month])
  @@index([tenantId, orgId, fiscalYear])
  @@map("journal_review_snapshot_months")
}

// ============================================================
// 決算検討 (year-end-review) 共有データ
//   担当者が複数いる前提で顧問先全体で共有する必要があるもの。
//   - tax-saving: 節税策チェック完了状態
//   - bs-cleanup: BS整理タスク (メモ・完了)
//   - year-end-schedule: スケジュール完了/日付上書き
//   - locaben-state: 業種上書き + 6指標 + 非財務4シート (顧問先全体で共有)
//   - feature-state: 汎用 KV (上記以外のセクション)
// ============================================================

/// 04 節税策チェック完了状態 (顧問先 × 会計年度 × 施策ID)
model TaxSavingDoneItem {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  fiscalYear  Int       @map("fiscal_year")
  itemId      String    @map("item_id")
  isDone      Boolean   @default(false) @map("is_done")
  doneAt      DateTime? @map("done_at")
  updatedById String?   @map("updated_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  updatedBy    User?        @relation("TaxSavingUpdater", fields: [updatedById], references: [id])

  @@unique([orgId, fiscalYear, itemId])
  @@index([tenantId, orgId, fiscalYear])
  @@map("tax_saving_done_items")
}

/// 06 BS整理タスク
model BsCleanupTask {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  fiscalYear  Int      @map("fiscal_year")
  /// 自動生成元の template キー (任意)
  templateKey String?  @map("template_key")
  category    String
  label       String
  amount      Decimal  @default(0) @db.Decimal(18, 2)
  hint        String   @default("")
  done        Boolean  @default(false)
  memo        String   @default("")
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  updatedBy    User?        @relation("BsCleanupUpdater", fields: [updatedById], references: [id])

  @@index([tenantId, orgId, fiscalYear])
  @@index([orgId, fiscalYear])
  @@map("bs_cleanup_tasks")
}

/// 07 決算スケジュール item 状態 (テンプレートIDごと)
model YearEndScheduleItemState {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  fiscalYear  Int      @map("fiscal_year")
  itemId      String   @map("item_id")
  isDone      Boolean  @default(false) @map("is_done")
  customDate  String?  @map("custom_date")
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  updatedBy    User?        @relation("YearEndScheduleUpdater", fields: [updatedById], references: [id])

  @@unique([orgId, fiscalYear, itemId])
  @@index([tenantId, orgId, fiscalYear])
  @@map("year_end_schedule_item_states")
}

/// ロカベン状態 (顧問先全体で共有、業種上書き + 6指標元データ + 非財務4シート)
model LocabenState {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  orgId            String   @unique @map("org_id") @db.Uuid
  industryOverride String?  @map("industry_override")
  /// 6指標元データ Record<SourceDataKey, number | null>
  values           Json     @default("{}")
  /// 非財務4シート Record<sectionKey, Record<fieldKey, string>>
  nonFinancial     Json     @default("{}") @map("non_financial")
  /// ユーザー入力フラグ Partial<Record<SourceDataKey, true>>
  manualKeys       Json     @default("{}") @map("manual_keys")
  updatedById      String?  @map("updated_by_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  updatedBy    User?        @relation("LocabenUpdater", fields: [updatedById], references: [id])

  @@unique([orgId, tenantId])
  @@index([tenantId, orgId])
  @@map("locaben_states")
}

/// 汎用 feature state (顧問先 × featureKey × scope で 1 レコード、 value は JSON)
/// 個別 table 化していないセクションの状態を保持する。
/// 例:
///   - "year-end-review.tax-forecast" / scope=fiscalYear → 税予想入力
///   - "year-end-review.cf-landing"   / scope=fiscalYear → 月別アウトフロー
///   - "variable-cost.custom"          / scope=""         → 変動費分類
model FeatureState {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  featureKey  String   @map("feature_key")
  /// 任意スコープ (会計年度等)。"" でグローバル扱い
  scope       String   @default("")
  value       Json     @default("{}")
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  updatedBy    User?        @relation("FeatureStateUpdater", fields: [updatedById], references: [id])

  @@unique([orgId, featureKey, scope])
  @@index([tenantId, orgId, featureKey])
  @@map("feature_states")
}

/// 借入金管理: 借入1本 = 1レコード。償還予定は LoanScheduleEntry に行単位で保持。
/// 「その月の残高」はスケジュール行から導出する(月末以前の直近 balanceAfter)。
model Loan {
  id               String              @id @default(uuid()) @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  orgId            String              @map("org_id") @db.Uuid
  /// 銀行・金融機関名(関係会社借入は会社名)
  lenderName       String              @map("lender_name")
  branchName       String?             @map("branch_name")
  /// 融資番号・取引番号
  loanNumber       String?             @map("loan_number")
  /// 証書貸付・手形貸付・当座貸越・関係会社借入 等(自由記述)
  loanType         String?             @map("loan_type")
  /// 借入総額(円)
  principal        BigInt
  /// 当初利率(%)。期中変動は LoanScheduleEntry.interestRate に行単位で保持
  interestRate     Decimal?            @map("interest_rate") @db.Decimal(6, 4)
  rateType         LoanRateType        @default(FIXED) @map("rate_type")
  /// 融資実行日
  startDate        DateTime?           @map("start_date") @db.Date
  termMonths       Int?                @map("term_months")
  /// 償還期限(期日一括はここで全額)
  maturityDate     DateTime?           @map("maturity_date") @db.Date
  repaymentMethod  LoanRepaymentMethod @default(EQUAL_INSTALLMENT) @map("repayment_method")
  /// 返済口座(表示用テキスト)
  repaymentAccount String?             @map("repayment_account")
  /// 原本の Google Drive 等のリンク(v1 は URL 保持のみ、同期なし)
  driveUrl         String?             @map("drive_url")
  memo             String?
  status           LoanStatus          @default(ACTIVE)
  /// 更新者(User.id)。リレーションは張らず参照のみ
  updatedById      String?             @map("updated_by_id") @db.Uuid
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  organization    Organization        @relation(fields: [orgId, tenantId], references: [id, tenantId])
  scheduleEntries LoanScheduleEntry[]
  documents       LoanDocument[]

  @@index([tenantId, orgId])
  @@map("loans")
}

enum LoanRateType {
  FIXED
  VARIABLE
}

enum LoanRepaymentMethod {
  /// 元利均等
  EQUAL_INSTALLMENT
  /// 元金均等
  EQUAL_PRINCIPAL
  /// 期日一括(利息のみ支払い期間あり)
  BULLET
  OTHER
}

enum LoanStatus {
  ACTIVE
  REPAID
}

/// 償還予定表の1行。銀行の返済予定表をそのまま写す(検算は API 層の決定論バリデータ)。
model LoanScheduleEntry {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  loanId          String   @map("loan_id") @db.Uuid
  /// 回数(表の「回数」。利息のみ行等で欠番があるため連番は強制しない)
  seq             Int
  dueDate         DateTime @map("due_date") @db.Date
  principalAmount BigInt   @map("principal_amount")
  interestAmount  BigInt   @map("interest_amount")
  totalAmount     BigInt   @map("total_amount")
  /// 返済後残高
  balanceAfter    BigInt   @map("balance_after")
  /// その回の適用利率(%)。公庫等の期中変動対応。NULL = Loan.interestRate
  interestRate    Decimal? @map("interest_rate") @db.Decimal(6, 4)
  /// 利率見直し等で金額未確定(別途通知待ち)の推定行
  isEstimated     Boolean  @default(false) @map("is_estimated")

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, seq])
  @@index([loanId, dueDate])
  @@index([tenantId])
  @@map("loan_schedule_entries")
}

/// アップロードされた返済予定表 PDF(Supabase Storage)。
/// 借入作成前のアップロード(抽出プレビュー段階)は loanId NULL。
model LoanDocument {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  loanId       String?  @map("loan_id") @db.Uuid
  fileName     String   @map("file_name")
  /// Supabase Storage のオブジェクトパス
  storagePath  String   @map("storage_path")
  contentType  String?  @map("content_type")
  sizeBytes    Int?     @map("size_bytes")
  /// アップロード者(User.id)。リレーションは張らず参照のみ
  uploadedById String?  @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId, tenantId], references: [id, tenantId])
  loan         Loan?        @relation(fields: [loanId], references: [id], onDelete: SetNull)

  @@index([tenantId, orgId])
  @@index([loanId])
  @@map("loan_documents")
}
