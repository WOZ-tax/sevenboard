# ============================================================
# SevenBoard Environment Variables
# Copy to .env and fill in values
# ============================================================

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sevenboard

# === API ===
JWT_SECRET=sevenboard-dev-secret-change-in-production
PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# === MoneyForward Cloud ===
MF_API_BASE_URL=https://accounting.moneyforward.com/api/v3
MF_ACCESS_TOKEN=                    # dev only (production uses per-org OAuth)
# MF_CLIENT_ID=                     # production OAuth
# MF_CLIENT_SECRET=                 # production OAuth
# MF_REDIRECT_URI=                  # production OAuth
# MF_TOKEN_ENCRYPTION_KEY=          # production AES-256

# === Claude AI ===
ANTHROPIC_API_KEY=                   # AIサマリー生成用

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_DEV_ORG_ID=           # dev shortcut

# === Redis (optional) ===
# REDIS_URL=

# === Monitoring ===
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
