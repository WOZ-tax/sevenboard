# SevenBoard API 環境変数テンプレート
# 本番 (Railway) ではダッシュボード上の Variables に登録すること。
# ローカルでは apps/api/.env にコピーして利用。

# ─── DB ────────────────────────────────────────────────
# Supabase 利用時は Dashboard の Database → Connection string → Transaction pooler (port 6543) をコピペ。
# 末尾に ?pgbouncer=true&connection_limit=1 を付与する。
# 新しめのプロジェクトは host が aws-1-<region>.pooler.supabase.com になるため自作禁止。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sevenboard

# ─── Auth ───────────────────────────────────────────────
# 本番は openssl rand -base64 48 で生成した値に置き換える。
JWT_SECRET=change-me-in-production

# ─── HTTP ───────────────────────────────────────────────
PORT=3001
# 本番は Vercel の URL（カンマ区切りで複数可）。
CORS_ORIGIN=http://localhost:3000

# ─── MoneyForward Cloud OAuth (パートナー API) ──────────────
MF_API_BASE_URL=https://accounting.moneyforward.com/api/v3
MF_CLIENT_ID=
MF_CLIENT_SECRET=
# 本番では https://<railway-host>/auth/mf/callback。MF パートナー管理画面に登録要。
MF_REDIRECT_URI=http://localhost:3001/auth/mf/callback
# MCP HTTP transport の resource indicator。authorize / token exchange / refresh の 3 か所すべてに必要。
MF_MCP_URL=https://beta.mcp.developers.biz.moneyforward.com/mcp/ca/v3

# ─── AI ─────────────────────────────────────────────────
# claude / gemini どちらでも runWithTools 対応。
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ─── 監視 (任意。当面なし) ─────────────────────────────────
SENTRY_DSN=

# ─── Kintone ───────────────────────────────────────────
KINTONE_BASE_URL=
KINTONE_USERNAME=
KINTONE_PASSWORD=
KINTONE_MONTHLY_APP_ID=
KINTONE_CUSTOMER_APP_ID=

# ─── 本番初期 seed (一度だけ) ──────────────────────────────
# IS_PRODUCTION_SEED=true で seed 実行すると owner ユーザー 1 名のみ作成する。
# 本番投入時のみ true にして、PRODUCTION_OWNER_PASSWORD を強パスワードで指定する。
IS_PRODUCTION_SEED=
PRODUCTION_OWNER_PASSWORD=
